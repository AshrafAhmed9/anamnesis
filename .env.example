# CockroachDB connection string (Cloud console → Connect → General connection string)
DATABASE_URL=cockroachdb+psycopg://<user>:<password>@<host>:26257/anamnesis?sslmode=verify-full

# AWS / Bedrock
AWS_REGION=us-east-1
BEDROCK_CHAT_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# Set to 1 to run entirely offline with a deterministic mock LLM/embeddings
# (used automatically by the test suite; useful for local dev without AWS creds)
ANAMNESIS_MOCK_LLM=0

# S3 bucket for consolidation reports (set by infra/template.yaml when deployed)
ANAMNESIS_REPORT_BUCKET=

# Optional: enables the ccloud ops sub-agent
COCKROACH_CLUSTER_ID=
